services:
  sonarr:
    image: linuxserver/sonarr:latest
    container_name: sonarr
    environment:
      - PUID={{ ansible_user_uid }}
      - PGID={{ ansible_user_gid }}
      - TZ=America/Chicago
    volumes:
      - {{ media_base_path }}/config/sonarr:/config
      - {{ media_base_path }}/data/tv:/tv
      - {{ media_base_path }}/data/downloads:/downloads
    ports:
      - 8989:8989
    restart: unless-stopped

  radarr:
    image: linuxserver/radarr:latest
    container_name: radarr
    environment:
      - PUID={{ ansible_user_uid }}
      - PGID={{ ansible_user_gid }}
      - TZ=America/Chicago
    volumes:
      - {{ media_base_path }}/config/radarr:/config
      - {{ media_base_path }}/data/movies:/movies
      - {{ media_base_path }}/data/downloads:/downloads
    ports:
      - 7878:7878
    restart: unless-stopped

  sabnzbd:
    image: linuxserver/sabnzbd:latest
    container_name: sabnzbd
    environment:
      - PUID={{ ansible_user_uid }}
      - PGID={{ ansible_user_gid }}
      - TZ=America/Chicago
    volumes:
      - {{ media_base_path }}/config/sabnzbd:/config
      - {{ media_base_path }}/data/downloads:/downloads
    ports:
      - 8085:8080
    restart: unless-stopped
